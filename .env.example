# ═══════════════════════════════════════════════════════════════════════
# Environment Variables Template
# Copy this file as .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════

# Server
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zorvyn_finance
DB_USERNAME=zorvyn
DB_PASSWORD=zorvyn_secret
DB_POOL_SIZE=20

# JWT
JWT_SECRET=your-super-secret-key-that-is-at-least-512-bits-long-change-this-in-production
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000

# Rate Limiting
RATE_LIMIT_RPM=100

# Idempotency
IDEMPOTENCY_TTL_HOURS=24

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
